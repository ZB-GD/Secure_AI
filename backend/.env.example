# SecLabs backend / RAG tutor — service-scoped configuration
#
# Copy this file to backend/.env and fill in the values:
#   cp backend/.env.example backend/.env
#
# This file is read directly by the tutor-rag service (via env_file in
# docker-compose.yml) and by the backend when run standalone with uvicorn.
# It is separate from the root .env, which configures the platform as a whole.

# Required: Google Gemini API key for the RAG tutor.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: comma-separated list of allowed frontend origins.
# Only needed when running the backend standalone (outside docker compose),
# where it is not already supplied by the root .env / docker-compose.yml.
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
