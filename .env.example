# SecLabs — local / generic deployment configuration
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Deploying to the Virtech VM (nattech.fib.upc.edu)? Use .env.virtech.example
# instead — it documents the NAT port mapping for that environment.

# ── Frontend / Vite build args ───────────────────────────────────────────────
# Leave these empty for Docker deployments: the browser calls the same origin
# and nginx proxies /health, /labs, /logs, /api to the backend container.
VITE_API_BASE_URL=
VITE_API_BASE_URL_FALLBACK=

# ── noVNC ─────────────────────────────────────────────────────────────────────
# Hostname/IP the browser uses to reach lab containers' noVNC interface.
NOVNC_HOST=localhost

# Comma-separated <docker-host-port>:<external-port> pairs for lab containers.
# Leave empty for local deployments where Docker publishes random host ports.
NOVNC_PORT_POOL=

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRE_HOURS=8

# Admin account seeded on first backend startup. Change the password after first login.
ADMIN_EMAIL=admin@seclabs.local
ADMIN_PASSWORD=replace-with-a-strong-password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins the backend allows. Must include wherever
# the frontend is served from.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Optional tuning ───────────────────────────────────────────────────────────

# How many lab containers can run at once.
MAX_CONCURRENT_LABS=20

# Seconds of inactivity before a lab container is stopped automatically.
LAB_HEARTBEAT_TIMEOUT_SECONDS=180

# How often the backend checks for idle lab containers to clean up.
LAB_CLEANUP_INTERVAL_SECONDS=30
