# Virtech (nattech.fib.upc.edu) deployment configuration
#
# Port math — replace XXX with the last octet of your VM's IP (e.g. 33 for 172.168.4.33):
#
#   Internal port  External NAT port        Role
#   8080           nattech.fib.upc.edu:40XX0   Frontend (nginx + API proxy)
#   8081           nattech.fib.upc.edu:40XX1   noVNC for Lab 1
#   8082           nattech.fib.upc.edu:40XX2   noVNC for Lab 2 (future)
#   ...
#   8089           nattech.fib.upc.edu:40XX9   noVNC for Lab 9 (future)
#
# Example for XXX=33: external ports are 40330 (frontend), 40331 (lab1), etc.
#
# This file only covers the platform-wide config (compose substitutes these
# into the relevant services). The RAG tutor needs its own GOOGLE_API_KEY in
# backend/.env — copy backend/.env.example -> backend/.env separately.

# ── noVNC ─────────────────────────────────────────────────────────────────────

# Hostname the browser uses to reach noVNC.
NOVNC_HOST=nattech.fib.upc.edu

# Comma-separated list of internal:external port pairs for lab containers.
# Format: <docker-host-port>:<external-nat-port>
# Ports 8081-8089 are all available (8080 is taken by the frontend).
NOVNC_PORT_POOL=8081:40XX1,8082:40XX2,8083:40XX3,8084:40XX4,8085:40XX5,8086:40XX6,8087:40XX7,8088:40XX8,8089:40XX9

# ── Frontend / CORS ───────────────────────────────────────────────────────────

# Origins the backend allows. Must include the external URL of the frontend.
# The frontend is served on port 8080 internally, which maps to 40XX0 externally.
CORS_ORIGINS=http://nattech.fib.upc.edu:40XX0

# ── Auth ──────────────────────────────────────────────────────────────────────

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRE_HOURS=8
ADMIN_EMAIL=admin@seclabs.local
ADMIN_PASSWORD=replace-with-a-strong-password

# ── Optional tuning ───────────────────────────────────────────────────────────

# How many lab containers can run at once. Must not exceed the number of
# entries in NOVNC_PORT_POOL above (the pool is the hard ceiling).
MAX_CONCURRENT_LABS=9

# Seconds of inactivity before a lab container is stopped automatically.
LAB_HEARTBEAT_TIMEOUT_SECONDS=180
